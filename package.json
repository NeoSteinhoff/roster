{
  "name": "roster-desktop",
  "version": "0.8.0",
  "description": "Roster desktop app for relationship tracking",
  "main": "electron-main.cjs",
  "scripts": {
    "start": "electron .",
    "package:mac": "electron-packager . Roster --platform=darwin --arch=arm64 --icon=assets/roster-logo.icns --app-version=$npm_package_version --build-version=$npm_package_version --overwrite --prune=true --out=dist"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-packager": "^17.1.2"
  }
}
